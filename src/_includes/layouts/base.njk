<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} — {{ site.name }}</title>
    <link rel="stylesheet" href="{{ "/assets/css/styles.css" | url }}">
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <div class="layout">
      <aside class="sidebar">
        <p class="sidebar__title"><a href="{{ "/" | url }}">{{ site.name }}</a></p>
        <p class="sidebar__institution">{{ site.institution }}</p>
        {% include "components/nav.njk" %}
        <div class="sidebar__contact">
          <p>Contact: <a href="mailto:{{ site.contactEmail }}">{{ site.contactEmail }}</a></p>
        </div>
      </aside>
      <main class="content" id="main-content">
        {{ content | safe }}
        <footer class="site-footer">
          <p>{{ site.name }} — {{ site.institution }}</p>
        </footer>
      </main>
    </div>
  </body>
</html>
